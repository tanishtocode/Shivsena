# ── SUBMIT PAGE ──────────────────────────────────────────────────────────────

msgid "Raise Your Voice"
msgstr "तुमचा आवाज उठवा"

msgid "Fill in the details below. We will review and take action as soon as possible."
msgstr "खाली तपशील भरा. आम्ही शक्य तितक्या लवकर आढावा घेऊ आणि कारवाई करू."

msgid "Before You Submit"
msgstr "सबमिट करण्यापूर्वी"

msgid "Describe your problem clearly and in detail"
msgstr "तुमची समस्या स्पष्टपणे आणि तपशीलवार सांगा"

msgid "Mention exact location or area of the problem"
msgstr "समस्येचे अचूक ठिकाण किंवा परिसर नमूद करा"

msgid "Attach a photo if possible — it helps resolve faster"
msgstr "शक्य असल्यास फोटो जोडा — यामुळे जलद निराकरण होते"

msgid "Provide correct contact so we can follow up"
msgstr "योग्य संपर्क द्या जेणेकरून आम्ही पाठपुरावा करू शकू"

msgid "Save your Ticket ID after submission to track status"
msgstr "स्थिती तपासण्यासाठी सबमिशननंतर तुमचा तिकीट आयडी जतन करा"

msgid "All complaints are reviewed within"
msgstr "सर्व तक्रारींचा आढावा"

msgid "24 hours"
msgstr "२४ तासांत"

msgid "Urgent issues like safety or water supply are prioritised."
msgstr "सुरक्षा किंवा पाणी पुरवठ्यासारख्या तातडीच्या समस्यांना प्राधान्य दिले जाते."

msgid "Need help filling the form?"
msgstr "फॉर्म भरण्यात मदत हवी आहे का?"

msgid "Call our office"
msgstr "आमच्या कार्यालयाला फोन करा"

msgid "Personal Details"
msgstr "वैयक्तिक तपशील"

msgid "optional"
msgstr "ऐच्छिक"

msgid "Your Address / Area"
msgstr "तुमचा पत्ता / परिसर"

msgid "e.g. Chikuwadi, Ward 5, Near Joggers Park"
msgstr "उदा. चिकुवाडी, वॉर्ड ५, जॉगर्स पार्कजवळ"

msgid "Complaint Details"
msgstr "तक्रारीचा तपशील"

msgid "Category"
msgstr "श्रेणी"

msgid "Select a category"
msgstr "एक श्रेणी निवडा"

msgid "Sanitation & Garbage"
msgstr "स्वच्छता व कचरा"

msgid "Other"
msgstr "इतर"

msgid "Exact Location of Problem"
msgstr "समस्येचे अचूक ठिकाण"

msgid "e.g. Near Bus Stop No. 12, Chikuwadi"
msgstr "उदा. बस स्टॉप क्र. १२ जवळ, चिकुवाडी"

msgid "Describe the Problem"
msgstr "समस्या वर्णन करा"

msgid "Explain the issue in detail. When did it start? How is it affecting you?"
msgstr "समस्या तपशीलवार सांगा. ती कधी सुरू झाली? ती तुम्हाला कशी प्रभावित करत आहे?"

msgid "characters"
msgstr "अक्षरे"

msgid "Priority Level"
msgstr "प्राधान्य पातळी"

msgid "Low"
msgstr "कमी"

msgid "Medium"
